<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Musical" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>
        <!-- primaryColor() (mini-player seekbar in Home/Library, app-shortcut icons) reads this -->
        <item name="colorPrimaryFixed">@color/md_theme_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>
        <item name="colorAccent">@color/md_theme_secondary</item>

        <!-- Keep control colors off the purple M3 defaults -->
        <item name="colorControlActivated">@color/md_theme_primary</item>

        <!-- Background & Surface Colors (Crucial for AMOLED & Light/Dark switching) -->
        <item name="android:colorBackground">@color/page_background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnBackground">@color/primary_text</item>
        <item name="colorOnSurface">@color/primary_text</item>

        <!-- M3 surface container tokens — used by dialogs, popups, bottom sheets, menus -->
        <item name="colorSurfaceContainerLow">@color/surface_container_low</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/surface_container_high</item>
        <item name="colorSurfaceContainerHighest">@color/surface_container_highest</item>

        <!-- Status & Navigation bar color -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/page_background</item>
        <item name="backgroundColor">@color/page_background</item>

        <!-- Wire dialogs into the app theme so they use app colors instead of M3 defaults -->
        <item name="materialAlertDialogTheme">@style/MaterialAlertDialogTheme</item>

        <!-- Preferences screen -->
        <item name="preferenceTheme">@style/DefaultPreferenceTheme</item>
    </style>
</resources>
