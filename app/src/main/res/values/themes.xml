<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Musical" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorAccent">@color/md_theme_secondary</item>

        <!-- Background & Surface Colors (Crucial for AMOLED & Light/Dark switching) -->
        <item name="android:colorBackground">@color/page_background</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnBackground">@color/primary_text</item>
        <item name="colorOnSurface">@color/primary_text</item>

        <!-- Status & Navigation bar color -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/page_background</item>

        <!-- Ensures edge-to-edge layouts work nicely with transparent bars -->
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
